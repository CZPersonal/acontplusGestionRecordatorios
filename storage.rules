rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // El usuario es miembro del tenant solicitado (mismo criterio que firestore.rules)
    function isMember(tid) {
      let data = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      return data.get('tenantIds', []).hasAny([tid]) || data.get('tenantId', '') == tid;
    }

    // Logo de la empresa: lectura pública (se embebe en correos enviados a
    // clientes, que no están autenticados), escritura solo para miembros del tenant.
    match /tenants/{tenantId}/logo/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && isMember(tenantId)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
