# Variables de entorno requeridas — copia este archivo a .env y rellena los valores
# Obtén estos datos en: Firebase Console → Tu proyecto → Configuración del proyecto → Tus apps

VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
VITE_FIREBASE_APP_ID=1:tu_sender_id:web:tu_app_hash
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Cloud Messaging — notificaciones push en segundo plano
# Firebase Console → Project Settings → Cloud Messaging → Web configuration → Generate key pair
VITE_FIREBASE_VAPID_KEY=

# Sentry — opcional; si está vacío no se inicializa Sentry
# Obtén el DSN en: sentry.io → Tu proyecto → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Firebase App Check — protege Firestore contra acceso directo con la API key
# 1. Registra la app en Firebase Console → App Check → Apps → reCAPTCHA v3
# 2. Obtén la site key en console.google.com/security/recaptcha
# Si está vacío, App Check no se inicializa (aceptable en desarrollo local)
VITE_RECAPTCHA_SITE_KEY=

# Token de debug para desarrollo local (opcional).
# Si no se define, el SDK genera uno automático y lo imprime en la consola del navegador.
# Cópialo y regístralo en Firebase Console → App Check → Apps → Debug tokens.
VITE_APP_CHECK_DEBUG_TOKEN=
