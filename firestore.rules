rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Perfil de usuario ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Tenant (empresa) ─────────────────────────────────────────────────────
    // Cualquier usuario autenticado puede crear un tenant (primer setup).
    // Solo miembros del tenant pueden leer / actualizar.
    match /tenants/{tenantId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null;
      allow update: if request.auth != null && isMember(tenantId);
      allow delete: if false;
    }

    // ─── Query de join por código (colección tenants, lectura limitada) ────────
    // Se permite listar tenants solo para buscar por joinCode desde TenantSetup.
    // La regla de tenant anterior cubre read de documento individual; esta cubre
    // el getDocs(query(collection('tenants'), where('joinCode','==',...))) .
    // Nota: Firestore evalúa la regla del documento destino, no del padre.
    // La regla match /tenants/{tenantId} con allow read cubre el list implícito
    // solo si el usuario ya es miembro. Para el join necesitamos allow list
    // sin validación de membresía — lo hacemos con una regla auxiliar:
    match /tenants/{tenantId} {
      allow read: if request.auth != null;  // list para búsqueda por joinCode
    }

    // ─── Helper: el usuario es miembro del tenant solicitado ─────────────────
    // Soporta tanto tenantIds (array, nuevo) como tenantId (string, migración)
    function isMember(tid) {
      let data = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return (data.get('tenantIds', []).hasAny([tid])) || (data.get('tenantId', '') == tid);
    }

    // ─── Helper: el usuario tiene rol admin en el tenant ─────────────────────
    // Si no existe el documento members/{uid} el default es 'admin' (retrocompatibilidad)
    function isAdmin(tid) {
      return get(/databases/$(database)/documents/tenants/$(tid)/members/$(request.auth.uid)).data.get('role', 'admin') == 'admin';
    }

    // ─── Miembros del tenant: roles ───────────────────────────────────────────
    match /tenants/{tenantId}/members/{uid} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null && isMember(tenantId) && request.auth.uid == uid;
      allow update: if request.auth != null && isAdmin(tenantId);
      allow delete: if false;
    }

    // ─── Datos del tenant: colecciones y subcolecciones ──────────────────────
    match /tenants/{tenantId}/water_filter_tasks/{taskId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.clientName is string
        && request.resource.data.clientName.size() > 0
        && request.resource.data.status is string;
      allow update: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.clientName is string
        && request.resource.data.clientName.size() > 0
        && request.resource.data.status is string;
      allow delete: if request.auth != null && isAdmin(tenantId);

      match /visits/{visitId} {
        allow read:           if request.auth != null && isMember(tenantId);
        allow create, update: if request.auth != null && isMember(tenantId);
        allow delete:         if request.auth != null && isAdmin(tenantId);
      }
    }

    match /tenants/{tenantId}/clients/{clientId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.identification is string
        && request.resource.data.identification.size() > 0;
      allow update: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    match /tenants/{tenantId}/service_types/{typeId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    match /tenants/{tenantId}/tecnicos/{tecnicoId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0;
      allow update: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0;
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    match /tenants/{tenantId}/tipos_visita/{tipoId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0;
      allow update: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0;
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    match /tenants/{tenantId}/configuracion/{docId} {
      allow read, write: if request.auth != null && isMember(tenantId);
    }

    match /tenants/{tenantId}/export_config/{docId} {
      allow read, write: if request.auth != null && isMember(tenantId);
    }

    match /tenants/{tenantId}/borradores/{borradoreId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null && isMember(tenantId)
        && request.resource.data.clientName is string
        && request.resource.data.clientName.size() > 0;
      allow update: if request.auth != null && isMember(tenantId);
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    // ─── Contadores atómicos (visitNumber, etc.) ─────────────────────────────
    match /tenants/{tenantId}/counters/{counterId} {
      allow read, write: if request.auth != null && isMember(tenantId);
    }

    // ─── Establecimientos (sucursales) ────────────────────────────────────────
    match /tenants/{tenantId}/establecimientos/{estId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null && isAdmin(tenantId)
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0;
      allow update: if request.auth != null && isAdmin(tenantId)
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0;
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    // ─── Nueva colección plana de visitas (reemplaza subcollecciones de tasks) ──
    match /tenants/{tenantId}/visits/{visitId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.clientName is string
        && request.resource.data.clientName.size() > 0
        && request.resource.data.status is string;
      allow update: if request.auth != null && isMember(tenantId);
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    match /tenants/{tenantId}/abonos/{abonoId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null && isMember(tenantId);
      allow update: if request.auth != null && isMember(tenantId);
      allow delete: if request.auth != null && isAdmin(tenantId);
    }

    match /tenants/{tenantId}/audit_log/{logId} {
      allow read:   if request.auth != null && isMember(tenantId);
      allow create: if request.auth != null
        && isMember(tenantId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Denegación por defecto ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
